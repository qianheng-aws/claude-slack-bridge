#!/usr/bin/env python3
"""Resolve the real Claude Code session_id for the current TUI.

Slash commands run inside a shell spawned by `claude`. There's no env var
or argv hint for "which session am I running in", so we reverse-engineer
it: Claude Code writes `~/.claude/sessions/<pid>.json` for every
interactive process with its real `sessionId`. Walking up our parent-
process chain finds that file for the exact TUI that invoked us.

On success: prints the session_id to stdout, exits 0.
On failure: prints a diagnostic dump to stderr, exits 1. Callers must
fail loudly — silently falling back to a heuristic (e.g. newest jsonl in
cwd) can bind to the wrong session when the cwd has parallel sessions.

Set SLACK_BRIDGE_RESOLVER_DEBUG=1 to log each candidate considered.
"""
from __future__ import annotations

import json
import os
import subprocess
import sys
from pathlib import Path


def _ppid_procfs(pid: int) -> int | None:
    try:
        with open(f"/proc/{pid}/status") as f:
            for line in f:
                if line.startswith("PPid:"):
                    return int(line.split()[1])
    except (OSError, ValueError):
        return None
    return None


def _ppid_ps(pid: int) -> int | None:
    # macOS has no /proc. `ps -o ppid= -p <pid>` is the POSIX portable
    # fallback and works on both macOS (BSD ps) and Linux.
    try:
        out = subprocess.check_output(
            ["ps", "-o", "ppid=", "-p", str(pid)],
            stderr=subprocess.DEVNULL, text=True, timeout=2,
        ).strip()
        return int(out) if out else None
    except (subprocess.SubprocessError, ValueError, OSError):
        return None


def _ppid(pid: int) -> int | None:
    return _ppid_procfs(pid) or _ppid_ps(pid)


def _same_path(a: str, b: str) -> bool:
    """Treat paths as equal if they resolve to the same filesystem location.

    Slash commands pass $PWD; Claude Code records whatever cwd was at the
    time its process started. Symlinks (/home vs /local/home, automount
    prefixes, trailing slashes) make naïve string compare miss matches.
    """
    if not a or not b:
        return False
    if a == b:
        return True
    try:
        return os.path.realpath(a) == os.path.realpath(b)
    except OSError:
        return False


def _is_path_prefix(ancestor: str, descendant: str) -> bool:
    """True if `ancestor` is a directory prefix of `descendant` (realpathed).

    Covers the "session's Bash tool cd'd into a subdirectory" case: the
    session file records the *start* cwd (/proj), while $PWD at slash-command
    time is deeper (/proj/src/pkg).
    """
    if not ancestor or not descendant:
        return False
    try:
        a = os.path.realpath(ancestor)
        d = os.path.realpath(descendant)
    except OSError:
        return False
    return d == a or d.startswith(a.rstrip("/") + "/")


def resolve_session_id(cwd: str, *, trace: list[str] | None = None) -> str | None:
    """Find this TUI's session id by walking up the parent-process chain.

    A process has exactly one ancestry, so any `interactive` ancestor with a
    session file is already an unambiguous identification of the TUI we are
    running inside — the recorded cwd can NOT overrule that. It is only used
    to *prefer* among multiple matching ancestors (nested `claude` in
    `claude`): exact cwd match first, then session-cwd-is-a-prefix-of-$PWD
    (the session cd'd deeper), then the nearest interactive ancestor.
    A hard cwd equality gate here previously rejected the correct session
    whenever its Bash tool had changed directory (2026-07-15 incident).
    """
    sessions_dir = Path.home() / ".claude" / "sessions"
    if not sessions_dir.is_dir():
        if trace is not None:
            trace.append(f"no sessions dir at {sessions_dir}")
        return None
    # (sid, exact_cwd, prefix_cwd) per interactive ancestor, nearest first.
    candidates: list[tuple[str, bool, bool]] = []
    pid = os.getpid()
    for _ in range(32):  # bound the walk
        pid = _ppid(pid) or 0
        if pid <= 1:
            if trace is not None:
                trace.append("reached init (ppid<=1)")
            break
        candidate = sessions_dir / f"{pid}.json"
        if not candidate.is_file():
            if trace is not None:
                trace.append(f"pid={pid}: no {candidate.name}")
            continue
        try:
            data = json.loads(candidate.read_text())
        except (OSError, json.JSONDecodeError) as e:
            if trace is not None:
                trace.append(f"pid={pid}: corrupt {candidate.name} ({e})")
            continue
        kind = data.get("kind")
        rec_cwd = data.get("cwd", "")
        sid = data.get("sessionId")
        if kind != "interactive":
            if trace is not None:
                trace.append(f"pid={pid}: kind={kind!r} (skip)")
            continue
        if not sid:
            if trace is not None:
                trace.append(f"pid={pid}: no sessionId field")
            continue
        exact = _same_path(rec_cwd, cwd)
        prefix = exact or _is_path_prefix(rec_cwd, cwd)
        if trace is not None:
            trace.append(
                f"pid={pid}: candidate sessionId={sid} "
                f"(cwd={'exact' if exact else 'prefix' if prefix else 'other'}: "
                f"record={rec_cwd!r} vs {cwd!r})"
            )
        candidates.append((str(sid), exact, prefix))
        if exact:
            break  # nearest exact match cannot be beaten
    else:
        if trace is not None:
            trace.append("walk bound (32 hops) reached")

    if not candidates:
        return None
    for want_exact, want_prefix in ((True, True), (False, True), (False, False)):
        for sid, exact, prefix in candidates:
            if exact >= want_exact and prefix >= want_prefix:
                if trace is not None:
                    tier = "exact-cwd" if want_exact else (
                        "cwd-prefix" if want_prefix else "nearest-ancestor")
                    trace.append(f"selected sessionId={sid} ({tier})")
                return sid
    return None  # unreachable — last tier accepts anything


def main() -> int:
    cwd = sys.argv[1] if len(sys.argv) > 1 else os.getcwd()
    debug = os.environ.get("SLACK_BRIDGE_RESOLVER_DEBUG")
    trace: list[str] | None = [] if debug else None
    sid = resolve_session_id(cwd, trace=trace)
    if sid:
        print(sid)
        if debug:
            for line in trace or []:
                print(f"[resolver] {line}", file=sys.stderr)
        return 0
    # Failure path: always dump diagnostics to stderr, not only in debug
    # mode. The caller is expected to fail loudly, and the user will need
    # this to file a bug.
    print("[resolver] could not find session_id via parent-pid walk", file=sys.stderr)
    if trace is None:
        trace = []
        resolve_session_id(cwd, trace=trace)
    for line in trace:
        print(f"[resolver] {line}", file=sys.stderr)
    print(f"[resolver] target cwd: {cwd}", file=sys.stderr)
    print(f"[resolver] resolver pid: {os.getpid()}", file=sys.stderr)
    return 1


if __name__ == "__main__":
    sys.exit(main())
